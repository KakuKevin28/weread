# Copy this file to .env on the Tencent Cloud server, then fill in your API key.
WEREAD_API_KEY=wrk-please_replace_with_your_api_key

# If MySQL is installed on the same Baota server, keep localhost.
# If you use TencentDB/CDB, replace host/user/password with the cloud database values.
WEREAD_MYSQL_HOST=localhost
WEREAD_MYSQL_PORT=3306
WEREAD_MYSQL_USER=weread
WEREAD_MYSQL_PASSWORD=please_replace_with_a_strong_password
WEREAD_MYSQL_DATABASE=weread_api

WEREAD_CONCURRENT_REQUESTS=4
WEREAD_DOWNLOAD_DELAY=0.25
WEREAD_RETRY_TIMES=3
WEREAD_LOG_LEVEL=INFO

# Web dashboard
WEREAD_WEB_HOST=0.0.0.0
WEREAD_WEB_PORT=5050
WEREAD_CACHE_TTL_SECONDS=600
